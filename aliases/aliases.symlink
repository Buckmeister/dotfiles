# vim:set ft=bash:
command -v exa >/dev/null 2>&1 && alias ls='exa --icons --git'
command -v batcat >/dev/null 2>&1 && alias bat='batcat'
command -v bat >/dev/null 2>&1 && alias cat='bat'
command -v fdfind >/dev/null 2>&1 && alias fd='fdfind'
command -v nvim >/dev/null 2>&1 && alias vi='nvim'

alias gitgraph='git log --decorate --graph'
alias R='R -q'
alias dddubd='docker-compose down && docker-compose up --build -d'
alias ponysay='ponysay -bround'
alias ponythink='ponythink -bunicode'
